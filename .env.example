# Copy this file to .env and fill in the values you want to override.
# Every variable below is optional — leaving one blank (or leaving out .env
# entirely) uses this service's built-in default from app.core.config.Settings
# (see that file for the actual default values), so `docker compose up
# --build` works with zero setup either way.

# --- PostgreSQL credentials (single source of truth) ---
# Used directly by the docker-compose "db" service AND by
# app.core.config.Settings to build the database connection string —
# change them here only, nothing else needs to be kept in sync manually.
POSTGRES_USER=
POSTGRES_PASSWORD=
POSTGRES_DB=
# Host-side port mapping for the "db" service (docker-compose only).
POSTGRES_PORT=

# --- Redis ---
# Host-side port mapping for the "redis" service (docker-compose only).
REDIS_PORT=

# --- API (docker-compose "api" service) ---
APP_PORT=

# --- Application settings (read by app.core.config.Settings) ---
APP_NAME=
APP_VERSION=
ENVIRONMENT=
LOG_LEVEL=

# --- JWT (read by app.core.config.Settings) ---
# Change this in any real deployment — Settings' built-in default is a
# dev-only placeholder, not a real secret.
JWT_SECRET_KEY=
JWT_ALGORITHM=
JWT_EXPIRE_SECONDS=

# --- Local (non-docker) overrides ---
# Inside docker-compose, Settings connects to "db"/"redis" on their internal
# container ports by default — correct for every container, so nothing
# above needs to change for `docker compose up` to work.
# To run the API directly on the host against the dockerized Postgres/Redis,
# set these so Settings targets the host-mapped ports instead:
POSTGRES_HOST=
REDIS_HOST=
