# --- PostgreSQL credentials (single source of truth) ---
# Used directly by the docker-compose "db" service AND by
# app.core.config.Settings to build the database connection string —
# change them here only, nothing else needs to be kept in sync manually.
POSTGRES_USER=postgres
POSTGRES_PASSWORD=asm@postgres
POSTGRES_DB=asm_db
# Host-side port mapping for the "db" service (docker-compose only).
POSTGRES_PORT=5432

# --- Redis ---
# Host-side port mapping for the "redis" service (docker-compose only).
REDIS_PORT=6379

# --- API (docker-compose "api" service) ---
APP_PORT=8000

# --- Application settings (read by app.core.config.Settings) ---
APP_NAME=ASM Asset Discovery Service
APP_VERSION=0.1.0
ENVIRONMENT=development
LOG_LEVEL=INFO

# --- JWT (read by app.core.config.Settings) ---
# Change this in any real deployment — the default is a dev-only placeholder.
JWT_SECRET_KEY=change-me-in-production-this-default-is-not-secret-at-all
JWT_ALGORITHM=HS256
JWT_EXPIRE_SECONDS=3600

# --- Local (non-docker) overrides ---
# Inside docker-compose, Settings connects to "db"/"redis" on their internal
# container ports (5432/6379) by default — correct for every container, so
# nothing above needs to change for `docker compose up` to work.
# To run the API directly on the host against the dockerized Postgres/Redis,
# uncomment these so Settings targets the host-mapped ports instead:
# POSTGRES_HOST=localhost
# REDIS_HOST=localhost
